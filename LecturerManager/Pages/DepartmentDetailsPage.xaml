<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:KMA.ProgrammingInCSharp2026.LecturerManager.Pages"
             xmlns:models="clr-namespace:KMA.ProgrammingInCSharp2026.LecturerManager.DTOModels.Lecturer;assembly=LecturerManager.DTOModels"
             xmlns:vms="clr-namespace:KMA.ProgrammingInCSharp2026.LecturerManager.ViewModels"
             x:Class="KMA.ProgrammingInCSharp2026.LecturerManager.Pages.DepartmentDetailsPage"
             x:DataType="vms:DepartmentDetailsViewModel"
             Title="Department Details">
    <Grid RowDefinitions="Auto,*">
        <Border 
            Grid.Row="0"
            Stroke="Blue" 
            Padding="10" 
            Margin="0,10">
            <VerticalStackLayout>
                <Label
                    Style="{StaticResource Headline}"
                    Text="{Binding CurrentDepartment.Name}"/>                
                <Label
                    Style="{StaticResource SubHeadline}"
                    Text="{Binding CurrentDepartment.Faculty, Converter={StaticResource EnumToDisplayName}}"
                    HorizontalOptions="Center"></Label>
                <Label
                    Text="{Binding CurrentDepartment.Email}"
                    HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>
        <Border 
            Grid.Row="1"
            VerticalOptions="Fill" 
            Stroke="Blue" 
            Padding="10" 
            Margin="0,10">
            <CollectionView
                ItemsSource="{Binding Lecturers}"
                Margin="10"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate
                            x:DataType="models:LecturerListDTO">
                        <Border
                            Stroke="Magenta"
                            Padding="10"
                            Margin="0,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vms:DepartmentDetailsViewModel}}, Path=LoadLecturerCommand}" 
                                    CommandParameter="{Binding Id}"/>                                
                            </Border.GestureRecognizers>
                            <VerticalStackLayout>
                                <Label
                                        Style="{StaticResource SubHeadline}">
                                    <Label.Text>
                                        <MultiBinding
                                                StringFormat="{}{0} {1}">
                                            <Binding Path="FirstName"></Binding>
                                            <Binding Path="LastName"></Binding>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label 
                                        Text="{Binding Position, Converter={StaticResource EnumToDisplayName}, StringFormat='Position: {0}'}"
                                        HorizontalOptions="Center"></Label>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>
    </Grid>
</ContentPage>