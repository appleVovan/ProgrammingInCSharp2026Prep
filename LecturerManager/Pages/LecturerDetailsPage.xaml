<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:KMA.ProgrammingInCSharp2026.LecturerManager.Pages"
             xmlns:models="clr-namespace:KMA.ProgrammingInCSharp2026.LecturerManager.DTOModels.Department;assembly=LecturerManager.DTOModels"
             xmlns:vms="clr-namespace:KMA.ProgrammingInCSharp2026.LecturerManager.ViewModels"
             x:Class="KMA.ProgrammingInCSharp2026.LecturerManager.Pages.LecturerDetailsPage"
             x:DataType="vms:LecturerDetailsViewModel"
             Title="LecturerDetailsPage" IsEnabled="{Binding IsNotBusy}">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="10,20" Spacing="10">
                <Label
                    Text="First Name"/>
                <Label
                    Text="{Binding FirstName}"
                    Margin="10,0"></Label>
                <Label
                    Text="Last Name"/>
                <Label
                    Text="{Binding LastName}"
                    Margin="10,0"></Label>
                <Label
                    Text="Position"/>
                <Label
                    Text="{Binding Position, Converter={StaticResource EnumToDisplayName}}"
                    Margin="10,0"></Label>
                <Label
                    Text="Date of birth"/>
                <Label
                    Text="{Binding DateOfBirth, StringFormat='{0:MMMM dd, yyyy}'}"
                    Margin="10,0"></Label>
                <Label
                    Text="Age"/>
                <Label
                    Text="{Binding Age}"
                    Margin="10,0"></Label>

            </VerticalStackLayout>
        </ScrollView>
        <BoxView
            IsVisible="{Binding IsBusy}"
            BackgroundColor="Gray"
            Opacity="0.2"
            InputTransparent="False"/>
        <ActivityIndicator
            Color="Magenta"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>
    </Grid>
</ContentPage>